# Portfolio demo defaults
APP_MODE=demo

# Required core runtime
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
DEFAULT_MODEL=gh/gpt-4.1

# Frontend
NEXT_PUBLIC_API_URL=https://your-modal-url.modal.run
BACKEND_CORS_ORIGINS=https://your-project.vercel.app

# Demo-friendly feature flags
ENABLE_LANGFUSE=false
ENABLE_QDRANT=false
ENABLE_VISUALIZATION=false
ENABLE_STARTUP_EMBEDDING_PREWARM=false
ARTIFACT_MODE=local
TYPE_OF_SANDBOX=none

# Optional: only enable if you intentionally demo these capabilities
# E2B_API_KEY=
# QDRANT_CLUSTER_ENDPOINT=
# QDRANT_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Optional tracing/logs
TRACE_JSONL_PATH=evals/reports/traces.jsonl
DEBUG_LOG_LEVEL=INFO
