*.sqlite

# Eval reports (managed via Docker volume)
evals/reports/

# Test files (not needed in production image)
tests/

# Dev/docs
docs/
*.md
CODEBASE_ANALYSIS.md
streamlit_app_original.py

# Backup files
*.backup.*
*.orig

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Temp
tmp/
*.tmp
*.log
