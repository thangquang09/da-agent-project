# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environment
.venv/
venv/
env/

# Git
.git/
.gitignore

# Large datasets (NOT needed in Docker image — seeded at runtime)
data/movie_lens/
data/spider_1/

